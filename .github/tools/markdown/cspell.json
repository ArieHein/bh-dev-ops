{
  "version": "0.2",
  "language": "en",
  "allowCompoundWords": true,
  "useGitignore": true,
  "dictionaries": [
    "platform-terms",
    "engineering-terms"
  ],
  "dictionaryDefinitions": [
    {
      "name": "platform-terms",
      "path": "./dictionaries/platform-terms.txt",
      "addWords": true
    },
    {
      "name": "engineering-terms",
      "path": "./dictionaries/engineering-terms.txt",
      "addWords": true
    }
  ],
  "ignorePaths": [
    "node_modules/**",
    ".git/**"
  ]
}